# ===========================================
# DOCKHAND CONFIGURATION
# ===========================================
# Copy to .env and update values:
#   cp example.env .env
#   nano .env

# ===========================================
# DATABASE CREDENTIALS
# ===========================================
PG_USER=dockhand
PG_PASS=changeMe                        # openssl rand -hex 32
PG_DB=dockhand

# ===========================================
# DOCKHAND APPLICATION (optional)
# ===========================================
# DOCKER_HOST=tcp://socket-proxy:2375   # Already configured via socket-proxy service
# DOCKHAND_PORT=3000                    # Internal listening port
# TZ=Europe/London                      # Timezone (default: UTC)
