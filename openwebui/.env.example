# Open WebUI — environment configuration
# Copy to .env and fill in the secret. DO NOT commit the .env.

# --- File ownership (PUID/PGID) ---------------------------------------------
# Host UID/GID that should own ./data. Run `id` to find yours.
PUID=1000
PGID=1000

# --- Locale ------------------------------------------------------------------
TZ=Europe/Bratislava

# --- CRITICAL: signs session cookies ---------------------------------------
# Without this set, the secret is regenerated every container restart and
# every user gets logged out. Losing this invalidates sessions but doesn't
# lose data; leaking it lets attackers forge them.
# Generate with:  openssl rand -hex 32
WEBUI_SECRET_KEY=change-me-64-hex-chars

# --- Auth toggle ------------------------------------------------------------
# true  = first-user-becomes-admin login flow (default, recommended)
# false = no login required (single-user / behind-Authentik proxy mode)
WEBUI_AUTH=true

# --- Host port binding ------------------------------------------------------
# 127.0.0.1-only; expose to the world via a reverse proxy.
OWUI_PORT=8071

# --- Optional: model provider (pick one or more) ----------------------------
# OLLAMA_BASE_URL points at an Ollama instance:
#   - Ollama on the host:        http://host.docker.internal:11434
#   - Ollama in another compose: http://ollama:11434 (and join that network)
# OLLAMA_BASE_URL=

# External API keys — set whichever providers you actually use.
# OPENAI_API_KEY=
# OPENAI_API_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=

# --- Optional: Authentik SSO (OIDC) -----------------------------------------
# Configure an Authentik OAuth2/OIDC provider, then:
# ENABLE_OAUTH_SIGNUP=true
# OAUTH_MERGE_ACCOUNTS_BY_EMAIL=true
# OAUTH_PROVIDER_NAME=authentik
# OPENID_PROVIDER_URL=https://auth.example.com/application/o/openwebui/
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# OAUTH_SCOPES=openid email profile
# OPENID_REDIRECT_URI=https://chat.example.com/oauth/oidc/callback
