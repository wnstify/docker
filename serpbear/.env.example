# SerpBear — environment configuration
# Copy to .env and fill in the required values. DO NOT commit the .env.

# --- File ownership (PUID/PGID) ---------------------------------------------
# Host UID/GID that should own ./data. The image's bundled non-root user
# is 1001:1001 (nextjs:nodejs); change only if you've chowned ./data to a
# different UID. Run `id` to find yours.
PUID=1001
PGID=1001

# --- Locale ------------------------------------------------------------------
TZ=Europe/Bratislava

# --- Host port binding ------------------------------------------------------
# 127.0.0.1-only; expose to the world via a reverse proxy.
SERPBEAR_PORT=3000

# --- REQUIRED: login credentials --------------------------------------------
# SerpBear has exactly one local user. PASSWORD is plaintext at rest in
# this file — treat .env as a secret.
SERPBEAR_USER=admin
# Use a strong password. Generate one with:  openssl rand -base64 24
SERPBEAR_PASSWORD=change-me-strong-password

# --- CRITICAL: signs session JWTs -------------------------------------------
# Without a stable SECRET, sessions invalidate on every restart. Leaking
# it lets attackers forge sessions.
# Generate with:  openssl rand -hex 32
SERPBEAR_SECRET=change-me-64-hex-chars

# --- CRITICAL: REST API bearer token ----------------------------------------
# Sent as `Authorization: Bearer <APIKEY>` to /api/* routes.
# Generate with:  openssl rand -hex 32
SERPBEAR_APIKEY=change-me-64-hex-chars

# --- Session lifetime (hours) -----------------------------------------------
SERPBEAR_SESSION_DURATION=24

# --- Public URL -------------------------------------------------------------
# What the app advertises to itself for emails / OAuth callbacks / CSRF
# origin checks. Include the scheme. Use your reverse-proxy hostname.
SERPBEAR_URL=https://seo.example.com

# --- Optional: Google Search Console integration ----------------------------
# Create a service account in Google Cloud, share read access on the
# property in Search Console, paste the JSON values here. The PRIVATE_KEY
# must include the literal `\n` newlines from the JSON.
# SEARCH_CONSOLE_CLIENT_EMAIL=
# SEARCH_CONSOLE_PRIVATE_KEY=

# --- Optional: SMTP for email notifications ---------------------------------
# Set these from the in-app Settings → Notifications panel instead of here
# if you prefer; values entered in the UI are stored in ./data/settings.json.
