# Uptime Kuma — environment configuration
# Copy to .env and fill in strong, unique values. DO NOT commit .env.

# --- Database credentials ----------------------------------------------------
# Generate strong values with:  openssl rand -base64 32
MARIADB_ROOT_PASSWORD=change-me-strong-root-password
UPTIME_KUMA_DB_NAME=uptime_kuma
UPTIME_KUMA_DB_USERNAME=uptime_kuma
UPTIME_KUMA_DB_PASSWORD=change-me-strong-app-password

# --- Optional ----------------------------------------------------------------
# Container timezone (log timestamps, scheduled monitor checks).
TZ=Europe/Bratislava
