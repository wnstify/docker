# FreshRSS — environment configuration
# Copy to .env and edit values. DO NOT commit the resulting .env.

# --- Locale ------------------------------------------------------------------
# Container timezone (log timestamps + cron schedule).
TZ=Europe/Bratislava

# --- Feed refresh schedule ---------------------------------------------------
# Minute field of the built-in crontab. Default fetches feeds at HH:03 and
# HH:33 (every 30 min, staggered to spread network load). Examples:
#   */15    every 15 minutes
#   0       once an hour, on the hour
#   ""      empty string disables the internal cron entirely
CRON_MIN=3,33
