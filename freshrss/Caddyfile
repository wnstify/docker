# Reverse proxy for FreshRSS — Caddy example.
# Replace rss.example.com with your domain. Caddy auto-provisions TLS.
#
# The compose sets TRUSTED_PROXY to include RFC1918 ranges, so FreshRSS
# trusts X-Forwarded-* headers from a proxy on a Docker bridge network.

rss.example.com {
    encode zstd gzip

    reverse_proxy http://127.0.0.1:88 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}
