# WireGuard + AdGuard — environment configuration
# Copy to .env and fill in the required values. DO NOT commit the .env.

# --- Locale ------------------------------------------------------------------
TZ=Europe/Bratislava

# --- REQUIRED: public reach for VPN clients ---------------------------------
# Public IP or DNS name your VPN clients dial in to. Must be reachable on
# UDP/51820 from the internet. Don't put a private IP here unless this
# server is only used by clients on the same LAN.
WG_HOST=vpn.example.com

# --- REQUIRED: bcrypt-hashed admin password for WG-Easy ---------------------
# WG-Easy stores the admin password as a bcrypt hash, not plaintext.
# Generate the hash with the helper image itself:
#
#   docker run --rm ghcr.io/wg-easy/wg-easy:15.3.0 node -e \
#     'console.log(require("bcryptjs").hashSync(process.argv[1], 10))' \
#     'YOUR-STRONG-PASSWORD'
#
# Then paste the output here and DOUBLE-ESCAPE every `$` as `$$`
# (docker compose interpolation eats single `$`).
PASSWORD_HASH=

# --- VPN client subnet ------------------------------------------------------
# CIDR your VPN clients receive addresses from. MUST be different from the
# docker `vpn_net` subnet (10.0.0.0/24 in the compose), otherwise you get
# routing loops. The `.x` token gets replaced with sequential client IPs.
WG_DEFAULT_ADDRESS=10.8.0.x

# DNS server VPN clients use. Default points to AdGuard's static IP on the
# docker `vpn_net`.
WG_DEFAULT_DNS=10.0.0.100

# IPs/CIDRs VPN clients can reach through the tunnel. `0.0.0.0/0, ::/0`
# means "everything" (full-tunnel VPN). Narrow it for split-tunnel.
WG_ALLOWED_IPS=0.0.0.0/0, ::/0

# --- Host port bindings -----------------------------------------------------
# WireGuard public listen port. Open this UDP port on your router/firewall.
WG_PORT=51820

# 127.0.0.1-bound web UI ports — expose to the world via a reverse proxy.
WG_UI_PORT=51821
ADGUARD_UI_PORT=8080
ADGUARD_SETUP_PORT=3000
