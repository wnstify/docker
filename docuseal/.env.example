# DocuSeal — environment configuration
# Copy to .env and fill in strong, unique values. DO NOT commit the .env.

# --- File ownership (PUID/PGID) ---------------------------------------------
# Host UID/GID that should own ./data/db. Postgres runs as this user.
# Run `id` to find yours.
PUID=1000
PGID=1000

# --- Locale ------------------------------------------------------------------
TZ=Europe/Bratislava

# --- Postgres credentials ----------------------------------------------------
# Two-user setup (least privilege):
#   POSTGRES_USER          — superuser, used ONLY for init (creating DB,
#                            running init-data.sh).
#   POSTGRES_NON_ROOT_USER — what DocuSeal actually connects as.
# Generate strong passwords with:  openssl rand -base64 36 | tr -d '\n'
POSTGRES_USER=postgres_admin
POSTGRES_PASSWORD=change-me-strong-postgres-root-password
POSTGRES_DB=docuseal

POSTGRES_NON_ROOT_USER=docuseal
POSTGRES_NON_ROOT_PASSWORD=change-me-strong-docuseal-db-password

# --- DocuSeal secrets --------------------------------------------------------
# CRITICAL: Rails secret_key_base — signs session cookies, CSRF tokens,
# and other security-sensitive values. Losing this invalidates all
# sessions; leaking it lets attackers forge them.
# Generate with:  openssl rand -hex 64
SECRET_KEY_BASE=change-me-128-hex-chars

# --- Public URL (must match your reverse proxy) -----------------------------
# Full external URL with scheme. Used to enforce HTTPS redirects.
FORCE_SSL=https://docuseal.example.com

# --- Host port binding ------------------------------------------------------
# 127.0.0.1-only; expose to the world via a reverse proxy.
DOCUSEAL_PORT=3000

# --- SMTP (optional, for invitation & notification emails) ------------------
# Leave blank if you don't need outbound email.
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=plain
SMTP_DOMAIN=
SMTP_FROM=docuseal@example.com
SMTP_ENABLE_STARTTLS_AUTO=true
