# Authentik — environment configuration
# Copy to .env and fill in strong, unique values. DO NOT commit the .env.

# --- File ownership (PUID/PGID) ---------------------------------------------
# Host UID/GID that should own ./data/*. Run `id` to find yours.
# Postgres, Redis, and the authentik server/worker containers all run as
# this UID:GID — no root in any container.
PUID=1000
PGID=1000

# --- Locale ------------------------------------------------------------------
TZ=Europe/Bratislava

# --- Postgres credentials ----------------------------------------------------
# Authentik's PG user owns the database and runs Django migrations as it.
# This matches the upstream authentik pattern (no separate non-root user).
# Generate a strong password with:  openssl rand -base64 36 | tr -d '\n'
PG_USER=authentik
PG_PASS=change-me-strong-postgres-password
PG_DB=authentik

# --- Authentik secret key (CRITICAL) ----------------------------------------
# Used to sign session cookies and other security-sensitive values.
# Losing this invalidates all sessions; leaking it lets attackers forge them.
# Generate with:  openssl rand -base64 60 | tr -d '\n'
AUTHENTIK_SECRET_KEY=change-me-very-long-secret-key

# --- Telemetry --------------------------------------------------------------
# Authentik reports errors to Sentry by default. Disable here for privacy;
# enable if you want to help the project debug crashes.
AUTHENTIK_ERROR_REPORTING__ENABLED=false

# --- Host port bindings -----------------------------------------------------
# 127.0.0.1-only; expose to the world via a reverse proxy.
COMPOSE_PORT_HTTP=9000
COMPOSE_PORT_HTTPS=9443

# --- SMTP (optional, for password reset & notification emails) --------------
# Leave blank if you don't need outbound email.
AUTHENTIK_EMAIL__HOST=
AUTHENTIK_EMAIL__PORT=587
AUTHENTIK_EMAIL__USERNAME=
AUTHENTIK_EMAIL__PASSWORD=
AUTHENTIK_EMAIL__USE_TLS=true
AUTHENTIK_EMAIL__USE_SSL=false
AUTHENTIK_EMAIL__TIMEOUT=10
AUTHENTIK_EMAIL__FROM=authentik@example.com

# --- Bootstrap admin (optional, first boot only) ----------------------------
# If set, authentik creates the initial admin (akadmin) with these creds on
# first start. After first boot they're ignored — change the admin password
# via the UI. Comment out if you prefer the interactive initial-setup flow at
# /if/flow/initial-setup/.
# AUTHENTIK_BOOTSTRAP_EMAIL=admin@example.com
# AUTHENTIK_BOOTSTRAP_PASSWORD=change-me-bootstrap-password
# AUTHENTIK_BOOTSTRAP_TOKEN=change-me-bootstrap-api-token
