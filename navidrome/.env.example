# Navidrome — environment configuration
# Copy to .env and adjust. No secrets are required to boot — only the
# music library path must be set.

# --- File ownership (PUID/PGID) ---------------------------------------------
# Host UID/GID that should own ./data and have read access to your music
# library. Run `id` to find yours.
PUID=1000
PGID=1000

# --- Locale ------------------------------------------------------------------
TZ=Europe/Bratislava

# --- REQUIRED: path to your music library on the host -----------------------
# Absolute path. Mounted into the container as /music (read-only).
MUSIC_DIR=/path/to/your/music

# --- Host port binding ------------------------------------------------------
# 127.0.0.1-only; expose to the world via a reverse proxy.
NAVIDROME_PORT=4533

# --- Tuning -----------------------------------------------------------------
ND_LOGLEVEL=info
ND_SCANSCHEDULE=1h
ND_SESSIONTIMEOUT=24h

# --- Optional: reverse-proxy subpath ----------------------------------------
# Set if you serve Navidrome at https://example.com/music/ instead of root.
# ND_BASEURL=/music

# --- Optional: Last.fm metadata enrichment (artist bios, similar artists) ---
# Get a free API key at https://www.last.fm/api/account/create
# ND_LASTFM_APIKEY=
# ND_LASTFM_SECRET=
# ND_LASTFM_LANGUAGE=en

# --- Optional: Spotify metadata enrichment (artist images) ------------------
# Register an app at https://developer.spotify.com/dashboard
# ND_SPOTIFY_ID=
# ND_SPOTIFY_SECRET=
