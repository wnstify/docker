# qBittorrent — environment configuration
# Copy to .env and adjust. DO NOT commit the .env.

# --- File ownership (PUID/PGID) ---------------------------------------------
# Host UID/GID that should own ./data and your downloads dir. Run `id` to
# find yours. These are passed via the compose `user:` directive so the
# image runs non-root and we can keep cap_drop: ALL with zero cap_add.
PUID=1000
PGID=1000

# --- Locale ------------------------------------------------------------------
TZ=Europe/Bratislava

# --- REQUIRED: legal-notice acknowledgement ---------------------------------
# The upstream image refuses to start without this. By setting it to
# "confirm" you affirm you've read qBittorrent's legal notice:
#   https://github.com/qbittorrent/qBittorrent/blob/master/src/app/main.cpp
QBT_LEGAL_NOTICE=confirm

# --- REQUIRED: path to your downloads directory on the host -----------------
# Absolute path. Mounted into the container as /downloads. Use the SAME
# host path your media server mounts so finished downloads appear in
# Jellyfin/Plex without an extra copy step.
#   e.g. DOWNLOADS_DIR=/media-data/downloads
DOWNLOADS_DIR=/path/to/your/downloads

# --- Host port bindings -----------------------------------------------------
# WebUI: 127.0.0.1-only; expose to the world via a reverse proxy.
QBT_WEBUI_HOST_PORT=9160

# BitTorrent listen port: published on ALL host interfaces (TCP + UDP).
# Forward this in your router/firewall so peers can connect inbound.
# Pick a port above 1024; do not use 6881 if your ISP throttles BT traffic.
QBT_TORRENT_PORT=6881
