# Jellyfin — environment configuration
# Copy to .env and edit values. DO NOT commit the resulting .env.

# --- LSIO image conventions --------------------------------------------------
# User/group that owns /config and (read-only) media on the host.
# Find yours with: id
PUID=1000
PGID=1000

# Container timezone (affects log timestamps + scheduled tasks).
TZ=Europe/Bratislava

# File-creation mask for any writes jellyfin does (logs, transcodes, etc.).
# 022 = files 644 / dirs 755. Use 002 if you need group-writable shared media.
UMASK=022
