# Zulip — environment configuration
# Copy to .env and fill in strong, unique values. DO NOT commit the .env.
#
# Tip: the `${VAR:?...}` syntax in docker-compose.yml will refuse to start
# the stack if any of the required secrets below is blank.

# --- Backend credentials -----------------------------------------------------
# Each protects one of the four backing services. They are independent —
# rotate any of them by stopping the stack, changing the value in BOTH
# this file and the matching service's persistent volume (or wipe the
# volume to re-init), then `docker compose up -d`.
#
# Generate strong values with:  openssl rand -base64 36 | tr -d '\n'
POSTGRES_PASSWORD=change-me-strong-postgres-password
MEMCACHED_PASSWORD=change-me-strong-memcached-password
RABBITMQ_DEFAULT_PASS=change-me-strong-rabbitmq-password
REDIS_PASSWORD=change-me-strong-redis-password

# --- Zulip Django SECRET_KEY (CRITICAL) -------------------------------------
# Signs session cookies, CSRF tokens, and password-reset links.
# Losing this invalidates every session; leaking it lets attackers forge them.
# Generate with:  openssl rand -base64 60 | tr -d '\n'
SECRETS_secret_key=change-me-very-long-secret-key

# --- Public-facing identity --------------------------------------------------
# Public hostname (NO scheme, NO trailing slash). Must match the reverse
# proxy config and any DNS records.
SETTING_EXTERNAL_HOST=zulip.example.com

# Email shown to users on the "contact your admin" link, and the From:
# address Zulip uses for system mails.
SETTING_ZULIP_ADMINISTRATOR=admin@example.com

# Comma-separated list of authentication backends. Common alternatives:
#   EmailAuthBackend,GoogleAuthBackend,GitHubAuthBackend,SAMLAuthBackend,LDAPAuthBackend
ZULIP_AUTH_BACKENDS=EmailAuthBackend

# --- TLS / reverse-proxy mode ------------------------------------------------
# True  = Zulip serves plain HTTP on :80, your reverse proxy terminates TLS
# False = Zulip self-terminates TLS on :443 (requires SSL_CERTIFICATE_GENERATION
#         set in compose; see https://zulip.readthedocs.io/projects/docker/)
ZULIP_HTTP_ONLY=True

# Host port (127.0.0.1-bound) where the reverse proxy reaches Zulip's :80.
COMPOSE_PORT_HTTP=8080

# Comma-separated IPs/CIDRs allowed to set X-Forwarded-* headers. REQUIRED
# when http_only=True — without it Zulip ignores X-Forwarded-Proto and
# generates http:// URLs in emails. Examples:
#   "10.0.0.0/8"          (typical bridge network)
#   "127.0.0.1,10.0.0.5"  (local Caddy + a separate proxy)
LOADBALANCER_IPS=127.0.0.1

# --- Outbound email (optional — leave SETTING_EMAIL_HOST blank to disable) --
# When enabled, Zulip sends password-reset, missed-message digest, and
# new-user-invitation emails through this SMTP host.
SETTING_EMAIL_HOST=
SETTING_EMAIL_HOST_USER=
SECRETS_email_password=
SETTING_EMAIL_PORT=587
SETTING_EMAIL_USE_TLS=True
SETTING_EMAIL_USE_SSL=False
NOREPLY_EMAIL_ADDRESS=noreply@example.com
