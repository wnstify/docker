# Reverse proxy for n8n — Caddy example.
# Replace n8n.example.com with your domain. Caddy auto-provisions TLS and
# transparently upgrades the editor's WebSocket connection.

n8n.example.com {
    encode zstd gzip

    # n8n reads X-Forwarded-* (with N8N_PROXY_HOPS=1) to know the real
    # client IP. Caddy sets X-Forwarded-For automatically.
    reverse_proxy http://127.0.0.1:5678 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}
