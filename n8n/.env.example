# n8n — environment configuration
# Copy to .env and fill strong, unique values. DO NOT commit the resulting .env.

# --- Postgres credentials ----------------------------------------------------
# Generate strong values with:  openssl rand -base64 24
POSTGRES_USER=postgres_admin
POSTGRES_PASSWORD=change-me-strong-postgres-root-password
POSTGRES_DB=n8n

# n8n connects to postgres as a NON-root user (created by init-data.sh on
# fresh DB init). Principle of least privilege — n8n never has superuser.
POSTGRES_NON_ROOT_USER=n8n
POSTGRES_NON_ROOT_PASSWORD=change-me-strong-n8n-db-password

# --- n8n secrets -------------------------------------------------------------
# CRITICAL: encrypts saved credentials in the database. If you lose this key
# AFTER saving credentials, those credentials are unrecoverable.
# Generate with:  openssl rand -hex 32
N8N_ENCRYPTION_KEY=change-me-64-hex-chars

# Shared secret between n8n and the runner — they authenticate task RPCs
# against each other with this token.
# Generate with:  openssl rand -base64 32
N8N_RUNNERS_AUTH_TOKEN=change-me-runner-shared-token

# --- Public URLs (must match your reverse proxy) -----------------------------
# Hostname only (no scheme, no trailing slash).
N8N_HOST=n8n.example.com

# Full external URL with trailing slash. n8n uses this to build webhook URLs
# and editor links so external services can reach back in.
WEBHOOK_URL=https://n8n.example.com/

# --- Locale ------------------------------------------------------------------
TZ=Europe/Bratislava
