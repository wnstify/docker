# Baserow — environment configuration
# Copy to .env and fill in strong, unique values. DO NOT commit the .env.

# --- Postgres credentials ----------------------------------------------------
# Generate strong values with:  openssl rand -base64 24
POSTGRES_USER=postgres_admin
POSTGRES_PASSWORD=change-me-strong-postgres-root-password
POSTGRES_DB=baserow

# baserow connects to postgres as a NON-root user (created by init-data.sh
# on fresh DB init). Principle of least privilege — baserow never has
# Postgres superuser.
POSTGRES_NON_ROOT_USER=baserow
POSTGRES_NON_ROOT_PASSWORD=change-me-strong-baserow-db-password

# --- Baserow secrets ---------------------------------------------------------
# CRITICAL: signs JWTs for user sessions. Losing this invalidates all
# sessions but doesn't lose data.
# Generate with:  openssl rand -hex 32
BASEROW_JWT_SIGNING_KEY=change-me-64-hex-chars

# Django SECRET_KEY — used for CSRF tokens, signed cookies, etc.
# Generate with:  openssl rand -hex 32
SECRET_KEY=change-me-django-secret-key

# Password for the Redis instance running INSIDE the all-in-one container.
# Generate with:  openssl rand -base64 24
REDIS_PASSWORD=change-me-redis-password

# --- Public URL (must match your reverse proxy config) -----------------------
# Full external URL with scheme. NO trailing slash (Baserow adds its own).
BASEROW_PUBLIC_URL=https://baserow.example.com

# --- LSIO-style file ownership ----------------------------------------------
# Host UID/GID that should own /baserow/data on disk. Run `id` to find yours.
PUID=1000
PGID=1000

# --- Locale ------------------------------------------------------------------
TZ=Europe/Bratislava
