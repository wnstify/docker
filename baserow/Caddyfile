# Reverse proxy for Baserow — Caddy example.
# Replace baserow.example.com with your domain. Caddy auto-provisions TLS
# and handles WebSocket upgrades (Baserow uses them for live collaboration).
#
# IMPORTANT: this MUST match BASEROW_PUBLIC_URL in your .env exactly —
# Baserow's internal Caddy matches the request's Host header against it.

baserow.example.com {
    encode zstd gzip

    reverse_proxy http://127.0.0.1:89 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}
